---
- name: Example Playbook
  hosts: localhost
  roles:
    - role: balena-etcher
    - role: docker
    - role: vscode
    - role: webmin
    # - role: add_user
    #   users:
    #     - name: mdh
    #       password: test
    #       groups:
    #         - docker
    #       nonsudo_allowed_sudo_commands: []
    # - role: vpn
{%- if args.networks is defined %}
  {%- for item in args.networks %}
    - role: NIC
      network_name: {{ item.name }}
      ethernet_interface_name: {{ item.name }}
      auto_connect: true
    {%- if item.ipv4 is defined %}
      ipv4: {{ item.ipv4 }}
    {%- else %}
      method4: auto
    {%- endif %}
    {%- if item.gateway4 is defined %}
      gateway4: {{ item.gateway4 }}
    {%- endif %}
    {%- if item.nameservers is defined %}
      nameservers:
      {%- for nameserver in item.nameservers %}
        - {{ nameserver }}
      {%- endfor %}
    {%- endif %}
  {%- endfor %}
{%- endif %}
{%- if args.linux_kernel is defined %}
{%- if args.linux_kernel.realtime is defined %}
{%- if args.linux_kernel.realtime.enable %}
    - role: realtime-patch
      vars:
        version_major: {{ args.linux_kernel.realtime.version_major | default(6) }}
        version_minor: {{ args.linux_kernel.realtime.version_minor | default(8) }}
        version_patch: {{ args.linux_kernel.realtime.version_patch | default(2) }}
        version_rt: {{ args.linux_kernel.realtime.version_rt | default(11) }}
        working_dir: /robot_mindset/linux_kernel
  {%- endif %}
{%- endif %}
{%- endif %}
