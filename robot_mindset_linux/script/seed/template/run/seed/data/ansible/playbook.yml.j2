---
- name: Example Playbook
  hosts: localhost
  roles:    
    # - role: add_user
    #   users:
    #     - name: mdh
    #       password: test
    #       groups:
    #         - docker
    #       nonsudo_allowed_sudo_commands: []
    # - role: vpn
{%- if args.networks is defined %}
  {%- for item in args.networks %}
    - role: NIC
      network_name: {{ item.name }}
      ethernet_interface_name: {{ item.name }}
      auto_connect: true
    {%- if item.ipv4 is defined %}
      ipv4: {{ item.ipv4 }}
    {%- else %}
      method4: auto
    {%- endif %}
    {%- if item.gateway4 is defined %}
      gateway4: {{ item.gateway4 }}
    {%- endif %}
    {%- if item.nameservers is defined %}
      nameservers:
      {%- for nameserver in item.nameservers %}
        - {{ nameserver }}
      {%- endfor %}
    {%- endif %}
  {%- endfor %}
{%- endif %}

